# Azure AD 應用程式註冊：https://portal.azure.com -> Azure Active Directory -> 應用程式註冊
TENANT_ID=your-tenant-id
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret

# 本機開發可改用裝置碼登入（留空 CLIENT_SECRET 並設為 true）
# DEVICE_CODE_FLOW=true

# Planner：二選一即可
# 方式一）GROUP_ID = Planner 網址中的 tid= 參數（建議，從瀏覽器網址列複製）
# 例：https://planner.cloud.microsoft/.../board?tid=611bbe5b-46a9-4bb3-9580-026cd900033f
GROUP_ID=your-group-id-from-url-tid
# 方式二）PLAN_ID = Graph API 的計畫 ID（若已知）
# PLAN_ID=your-plan-id

# OneNote 週報要寫入的 section ID（從 Graph 查 notebook/sections）
ONENOTE_SECTION_ID=your-onenote-section-id

# --- 方案 B：Power Automate 後端（不需管理員核准時）---
# USE_POWER_AUTOMATE=true
# HTTP 觸發（需 Premium）：FLOW_PLANNER_URL=https://...
# 手動觸發：Flow 將結果寫入檔案，Agent 讀取。請設 TASKS_INPUT_FILE（本機路徑，例如 OneDrive 同步後的檔案）
# TASKS_INPUT_FILE=C:\Users\你的帳號\OneDrive\PlannerAgent\tasks_output.json
# FLOW_CALENDAR_URL=...（建立 Outlook 事件；schedule-nextweek 會呼叫此 Flow）
# FLOW_ONENOTE_URL=https://...

# 選填（Planner 優先：1=低 5=中 9=高 10=緊急；HIGH_PRIORITY_THRESHOLD 以上才顯示，0=全部）
DEFAULT_TASK_DURATION_MINUTES=60
DUE_WITHIN_DAYS=7
HIGH_PRIORITY_THRESHOLD=7

# 下週待排清單（nextweek）：時區與欄位名稱
# LOCAL_TIMEZONE=Asia/Taipei
# NEXT_WEEK_BUCKETS=本週工作,進行中
# NOT_STARTED_BUCKET=未開始
